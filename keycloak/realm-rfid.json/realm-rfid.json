{
  "realm": "rfid-realm",
  "displayName": "RFID Traslados",
  "displayNameHtml": "<b>RFID</b> Traslados",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "accessTokenLifespan": 900,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionMaxLifespan": 5184000,

  "roles": {
    "realm": [
      {
        "name": "ROLE_ADMIN",
        "description": "Administrador del sistema RFID — acceso total sin restricciones",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "ROLE_OPERATOR",
        "description": "Operador de almacén o tienda — crea traslados, despacha, recibe",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "ROLE_READER",
        "description": "Auditor o sistema externo — solo endpoints GET de consulta",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "ROLE_DEVICE",
        "description": "Lector RFID o PDA — solo POST rfid-validations y read-tags",
        "composite": false,
        "clientRole": false
      }
    ]
  },

  "clients": [
    {
      "clientId": "rfid-frontend",
      "name": "RFID Frontend Web SPA",
      "description": "Aplicación web SPA — OAuth2 Authorization Code + PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://38.253.180.55/*",
        "http://38.253.180.55/",
        "http://localhost:3000/*",
        "http://localhost/*",
        "http://127.0.0.1:*/*"
      ],
      "webOrigins": [
        "http://38.253.180.55",
        "http://localhost:3000",
        "http://localhost",
        "http://127.0.0.1"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://38.253.180.55/*##http://localhost:3000/*##http://localhost/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "rfid-backend",
      "name": "RFID Backend Resource Server",
      "description": "Bearer-only — microservicios Java validan tokens aquí",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "rfid-device",
      "name": "RFID Device Client",
      "description": "Lectores RFID y PDAs — client_credentials grant",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "secret": "rfid-device-secret-2026",
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles"
      ]
    }
  ],

  "users": [
    {
      "username": "admin.rfid",
      "email": "admin@rfid.pystelectronic.com",
      "firstName": "Administrador",
      "lastName": "RFID",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Admin@2026!", "temporary": false }
      ],
      "realmRoles": ["ROLE_ADMIN"]
    },
    {
      "username": "operador.almacen",
      "email": "almacen@rfid.pystelectronic.com",
      "firstName": "Operador",
      "lastName": "Almacén",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Oper@2026!", "temporary": false }
      ],
      "realmRoles": ["ROLE_OPERATOR"]
    },
    {
      "username": "operador.tienda",
      "email": "tienda@rfid.pystelectronic.com",
      "firstName": "Operador",
      "lastName": "Tienda",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Tienda@2026!", "temporary": false }
      ],
      "realmRoles": ["ROLE_OPERATOR"]
    },
    {
      "username": "auditor.rfid",
      "email": "auditor@rfid.pystelectronic.com",
      "firstName": "Auditor",
      "lastName": "RFID",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Audit@2026!", "temporary": false }
      ],
      "realmRoles": ["ROLE_READER"]
    }
  ],

  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';"
  },
  "smtpServer": {},
  "eventsEnabled": false,
  "adminEventsEnabled": false
}
